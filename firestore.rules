rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to validate product ID format
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() < 100;
    }
    
    // Helper to validate product schema
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'category', 'price', 'image', 'description', 'inStock'])
        && data.name is string && data.name.size() > 0 && data.name.size() < 200
        && data.category is string && data.category.size() > 0 && data.category.size() < 100
        && (data.price is number || data.price is int) && data.price >= 0
        && data.image is string && data.image.size() > 0 && data.image.size() < 1000000
        && data.description is string && data.description.size() > 0 && data.description.size() < 5000
        && data.inStock is bool;
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isValidId(productId) && (request.resource == null || isValidProduct(request.resource.data));
    }

    match /categories/{categoryId} {
      allow read, write: if true;
    }

    match /settings/{settingsId} {
      allow read, write: if true;
    }

    match /orders/{orderId} {
      allow read, write: if true;
    }

    match /messages/{messageId} {
      allow read, write: if true;
    }
  }
}
